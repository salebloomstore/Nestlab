# =====================================================
# NUXT SSR DOCKER IMAGE
# =====================================================

FROM node:22-alpine


# =====================================================
# SET WORKING DIRECTORY
# =====================================================

WORKDIR /app


# =====================================================
# COPY START SCRIPT
# =====================================================

COPY ./run.sh /run.sh


# =====================================================
# MAKE SCRIPT EXECUTABLE
# =====================================================

RUN chmod +x /run.sh


# =====================================================
# START CONTAINER
# =====================================================

CMD ["/run.sh"]
